# Copy to ../.env (the e2e folder). See e2e/.gitignore.

E2E_BASE_URL=http://localhost:3000
# Backend URL for US-1.1 E2E: fetch verification code (requires backend e2e.expose-verification-code=true)
E2E_API_BASE_URL=http://localhost:8000
# Same value as backend e2e.verification-secret (sent as X-E2E-Secret)
E2E_VERIFICATION_SECRET=
# If set, signup test registers as local+e2e<uuid>@domain (Gmail-friendly) to avoid duplicate email errors
E2E_SIGNUP_EMAIL=
E2E_SIGNUP_PASSWORD=E2E_Signup_Pass_1!
E2E_SIGNUP_FIRST_NAME=E2E
E2E_SIGNUP_LAST_NAME=Signup

E2E_EMAIL_OR_PHONE=
E2E_PASSWORD=

E2E_SEARCH_KEYWORD=
E2E_FILTER_CATEGORY_NAME=
E2E_FILTER_LOCATION_NAME=
E2E_FILTER_START_DATE=
E2E_FILTER_END_DATE=

E2E_EPIC3_EVENT_TITLE=
E2E_SOLD_OUT_EVENT_TITLE=

E2E_ADMIN_EMAIL_OR_PHONE=
E2E_ADMIN_PASSWORD=

E2E_ADD_EVENT_TITLE=
E2E_ADD_EVENT_DESCRIPTION=
E2E_ADD_EVENT_DATETIME=
E2E_ADD_EVENT_CATEGORY=
E2E_ADD_EVENT_LOCATION=
E2E_ADD_EVENT_TICKETS=

E2E_EDIT_EVENT_TITLE=
E2E_EDIT_TEMP_TITLE=
E2E_EDIT_EVENT_DESCRIPTION=
E2E_EDIT_EVENT_DATETIME=
E2E_EDIT_EVENT_CATEGORY=
E2E_EDIT_EVENT_LOCATION=
E2E_EDIT_EVENT_TICKETS=

E2E_CANCEL_EVENT_TITLE=
E2E_CANCEL_EVENT_DESCRIPTION=
E2E_CANCEL_EVENT_DATETIME=
E2E_CANCEL_EVENT_CATEGORY=
E2E_CANCEL_EVENT_LOCATION=
E2E_CANCEL_EVENT_TICKETS=
